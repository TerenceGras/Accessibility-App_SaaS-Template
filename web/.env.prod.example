# LumTrails Frontend Environment Variables - PRODUCTION
# Copy this file to .env.prod and fill in your own values.
# Domain: your-domain.com

# API Configuration (Cloud Run PROD URLs)
# Replace YOUR_PROJECT_NUMBER with your GCP project number
VITE_API_URL=https://lumtrails-api-YOUR_PROJECT_NUMBER.europe-west1.run.app
VITE_REPORT_GENERATOR_URL=https://lumtrails-report-generator-YOUR_PROJECT_NUMBER.europe-west1.run.app
VITE_MAILING_URL=https://lumtrails-mailing-YOUR_PROJECT_NUMBER.europe-west1.run.app

# Firebase Configuration (production project)
VITE_FIREBASE_API_KEY=YOUR_PROD_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROD_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROD_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROD_PROJECT_ID.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_PROD_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_PROD_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=

# Stripe Configuration - PRODUCTION KEYS
# NOTE: Use pk_live_... for production (not pk_test_...)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_PRODUCTION_STRIPE_KEY
VITE_PRICING_API_URL=https://lumtrails-pricing-YOUR_PROJECT_NUMBER.europe-west1.run.app
