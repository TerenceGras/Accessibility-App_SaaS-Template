# LumTrails Frontend Environment Variables
# 
# QUICK START:
# 1. Copy this file to .env.dev (for development) or .env.prod (for production)
# 2. Fill in your own values
# 3. The deploy scripts copy the appropriate file to .env automatically
#
# NOTE: .env.dev and .env.prod are NOT tracked in git.

# ============================================
# Environment
# ============================================
# Set to "production" for prod, leave empty for dev
VITE_ENVIRONMENT=

# ============================================
# API Configuration (Cloud Run URLs)
# ============================================
# Replace YOUR_PROJECT_NUMBER with your GCP project number
VITE_API_URL=https://lumtrails-api-YOUR_PROJECT_NUMBER.europe-west1.run.app
VITE_REPORT_GENERATOR_URL=https://lumtrails-report-generator-YOUR_PROJECT_NUMBER.europe-west1.run.app
VITE_PRICING_API_URL=https://lumtrails-pricing-YOUR_PROJECT_NUMBER.europe-west1.run.app
VITE_MAILING_URL=https://lumtrails-mailing-YOUR_PROJECT_NUMBER.europe-west1.run.app

# ============================================
# Firebase Configuration
# ============================================
# Get these from Firebase Console > Project Settings
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_FIREBASE_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=

# ============================================
# Google Analytics 4 (optional, production only)
# ============================================
VITE_GA_MEASUREMENT_ID=

# ============================================
# Stripe Configuration
# ============================================
# Use pk_test_... for development, pk_live_... for production
VITE_STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY
