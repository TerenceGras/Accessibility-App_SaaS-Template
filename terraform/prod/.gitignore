# Terraform State Files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Terraform lock file (can be committed for reproducible builds)
# Uncomment if you want to ignore it
# .terraform.lock.hcl

# Terraform directory
.terraform/

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include tfvars files for sensitive values
# *.tfvars
# *.tfvars.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Plan output files
tfplan
